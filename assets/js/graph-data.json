---
layout: null
---
{% assign nodes = "" | split: "" %}
{% assign links = "" | split: "" %}

{% comment %} Post nodes {% endcomment %}
{% for post in site.posts %}
  {% capture node %}{"id":"post-{{ forloop.index }}","type":"{% if post.post_type == 'project' %}project{% else %}post{% endif %}","label":"{{ post.title | escape }}","url":"{{ post.url | relative_url }}","tags":[{% for tag in post.tags %}"{{ tag | escape }}"{% unless forloop.last %},{% endunless %}{% endfor %}],"date":"{{ post.date | date: '%Y-%m-%d' }}"}{% endcapture %}
  {% assign nodes = nodes | push: node %}
{% endfor %}

{% comment %} Project collection nodes {% endcomment %}
{% for project in site.projects %}
  {% capture node %}{"id":"project-{{ forloop.index }}","type":"project","label":"{{ project.title | escape }}","url":"{{ project.url | relative_url }}","tags":[{% for tag in project.tags %}"{{ tag | escape }}"{% unless forloop.last %},{% endunless %}{% endfor %}],"date":"{{ project.date | date: '%Y-%m-%d' }}"}{% endcapture %}
  {% assign nodes = nodes | push: node %}
{% endfor %}

{% comment %} Tag nodes {% endcomment %}
{% for tag in site.tags %}
  {% capture node %}{"id":"tag-{{ tag[0] | slugify: 'none' }}","type":"tag","label":"{{ tag[0] | escape }}","url":"/tags/#{{ tag[0] | slugify: 'none' }}","count":{{ tag[1].size }}}{% endcapture %}
  {% assign nodes = nodes | push: node %}
{% endfor %}

{% comment %} Links: post -> tag {% endcomment %}
{% for post in site.posts %}
  {% for tag in post.tags %}
    {% capture link %}{"source":"post-{{ forloop.parentloop.index }}","target":"tag-{{ tag | slugify: 'none' }}"}{% endcapture %}
    {% assign links = links | push: link %}
  {% endfor %}
{% endfor %}

{% comment %} Links: project collection -> tag {% endcomment %}
{% for project in site.projects %}
  {% for tag in project.tags %}
    {% capture link %}{"source":"project-{{ forloop.parentloop.index }}","target":"tag-{{ tag | slugify: 'none' }}"}{% endcapture %}
    {% assign links = links | push: link %}
  {% endfor %}
{% endfor %}

{
  "nodes": [{% for node in nodes %}{{ node }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  "links": [{% for link in links %}{{ link }}{% unless forloop.last %},{% endunless %}{% endfor %}]
}
